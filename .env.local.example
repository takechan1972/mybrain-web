# 本番サイトURL（Vercel 本番デプロイ後に設定する）。Google / Apple OAuth の redirectTo に使用。
# ローカル開発では未設定でOK（window.location.origin が自動で使われる）。
NEXT_PUBLIC_SITE_URL=

# Supabase（接続準備）。値は各自のSupabaseプロジェクト → Project Settings → API から取得。
# 公開前提の鍵（フロントで使用可）。
NEXT_PUBLIC_SUPABASE_URL=
# どちらか一方でOK（ANON_KEY を優先。無ければ PUBLISHABLE_KEY を使用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# サーバ専用（フロントに出さない）。NEXT_PUBLIC_ を付けないこと。
# service_role secret は強い秘密キー。フロントでは絶対に使わない（今は空でOK）。
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
