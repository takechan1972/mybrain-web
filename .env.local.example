# 本番サイトURL（Vercel 本番デプロイ後に設定する）。Google / Apple OAuth の redirectTo に使用。
# ローカル開発では未設定でOK（window.location.origin が自動で使われる）。
NEXT_PUBLIC_SITE_URL=

# Supabase（接続準備）。値は各自のSupabaseプロジェクト → Project Settings → API から取得。
# 公開前提の鍵（フロントで使用可）。
NEXT_PUBLIC_SUPABASE_URL=
# どちらか一方でOK（ANON_KEY を優先。無ければ PUBLISHABLE_KEY を使用）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# サーバ専用（フロントに出さない）。NEXT_PUBLIC_ を付けないこと。
# service_role secret は強い秘密キー。フロントでは絶対に使わない（今は空でOK）。
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Google Drive manual export
# Enable this only when a Google Drive API / OAuth client is configured.
# Used by the existing manual "Google Driveへ書き出し" feature (DesktopMemos).
# Set the same values in Vercel Project Settings > Environment Variables for production.
#
# 注意（安全メモ）:
# - CLIENT_ID は「公開前提」の値です。ブラウザの GIS トークンフローで使うため NEXT_PUBLIC_ で露出してよい。
# - client secret（クライアントシークレット）はここに絶対に書かない。
# - refresh token（リフレッシュトークン）を env に保存しない。
# - 現在の実装は「ユーザー操作（クリック）起点の手動エクスポート」＋「短命アクセストークン（メモリのみ）」。
# - 保存先 "obsidian-gdrive"（自動保存）はまだ未実装（自動書き出しはしない）。
NEXT_PUBLIC_GOOGLE_DRIVE_ENABLED=false
NEXT_PUBLIC_GOOGLE_DRIVE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
