{
  "expo": {
    "name": "AIプラ",
    "slug": "AI_iphone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aiiphone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "jp.aipla.app",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "android": {
      "package": "jp.aipla.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 160
          }
        }
      ],
      "expo-audio",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "音声入力でメモや予定を登録するためにマイクを使用します。",
          "speechRecognitionPermission": "話した内容を文字に変換し、メモや予定に入力するために音声認識を使用します。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "メモに添付する画像を選ぶために写真ライブラリを使用します。",
          "cameraPermission": "メモに添付する写真を撮影するためにカメラを使用します。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a288a33e-0456-4044-ba0a-c9e9afded101"
      }
    },
    "owner": "takemotoyasutaka"
  }
}
