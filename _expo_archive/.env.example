# AIプラ スマホ版 環境変数の例
# このファイルをコピーして .env を作成してください（.env はGit管理しません）。
# Expo の EXPO_PUBLIC_ プレフィックスはアプリ側から参照できます。

# バックエンド接続先（origin。例: https://api.example.com）
# 未設定の場合：
#   - development では http://localhost:8787 を使用
#   - production では接続せず、ユーザーへ「接続設定が完了していません」と案内
EXPO_PUBLIC_API_BASE_URL=

# 実行環境: development / production
# production では EXPO_PUBLIC_API_BASE_URL が必須（localhostへフォールバックしません）
EXPO_PUBLIC_APP_ENV=development
